From ccc4283f48592efe47b41d2f44330cbadfa73e4d Mon Sep 17 00:00:00 2001
From: Justin Le <justin@jle.im>
Date: Wed, 25 Aug 2021 21:58:16 -0700
Subject: [PATCH] fix functions on singleton containers (NEMap.deleteMax)

Hand-crafted slice of upstream commit ccc4283 against modern HEAD: only
the NEMap.deleteMax hunk. The buggy form `insertMinMap k v . M.deleteMax`
returns the singleton itself when the underlying inner map is empty,
because M.deleteMax on empty Map is a no-op and insertMinMap re-creates
the singleton.
---
 src/Data/Map/NonEmpty.hs | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/src/Data/Map/NonEmpty.hs b/src/Data/Map/NonEmpty.hs
index aaaaaaa..bbbbbbb 100644
--- a/src/Data/Map/NonEmpty.hs
+++ b/src/Data/Map/NonEmpty.hs
@@ -2226,7 +2226,9 @@
 -- > deleteMax (fromList ((5,"a") :| [(3,"b"), (7,"c")])) == Data.Map.fromList [(3,"b"), (5,"a")]
 -- > deleteMax (singleton 5 "a") == Data.Map.empty
 deleteMax :: NEMap k a -> Map k a
-deleteMax (NEMap k v m) = insertMinMap k v . M.deleteMax $ m
+deleteMax (NEMap k v m) = case M.maxView m of
+  Nothing -> M.empty
+  Just (_, m') -> insertMinMap k v m'
 {-# INLINE deleteMax #-}

 -- | /O(1)/ if delete, /O(log n)/ otherwise. Update the value at the
